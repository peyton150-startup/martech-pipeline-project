{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "destination_viewed",
  "title": "destination_viewed",
  "description": "Fired when a destination detail page renders. The category drives audience segmentation.",
  "type": "object",
  "required": ["event", "event_id", "timestamp", "destination", "consent_state"],
  "properties": {
    "event": { "const": "destination_viewed" },
    "event_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "destination": {
      "type": "object",
      "required": ["slug", "category"],
      "properties": {
        "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "category": { "enum": ["beach", "ski", "city"] },
        "region": { "type": "string" },
        "price_from": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "consent_state": { "enum": ["granted", "denied", "pending"] }
  },
  "additionalProperties": false
}

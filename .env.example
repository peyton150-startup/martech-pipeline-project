# GTM container ID — set in .env.local after day 2
NEXT_PUBLIC_GTM_ID=

# GTM environment targeting (Admin → Environments → your env → install
# snippet carries these). Leave unset to serve the Live version.
# Promote/rollback flow: docs/runbook.md.
NEXT_PUBLIC_GTM_AUTH=
NEXT_PUBLIC_GTM_PREVIEW=

# ETL only (scripts/etl.mjs, live mode) — personal API key, query:read scope.
# Never NEXT_PUBLIC_, never committed.
POSTHOG_PERSONAL_API_KEY=

# PostHog configuration — set in .env.local (or Vercel env vars).
# The phc_ project key is a public client-side token (safe to expose in the
# browser bundle). Demo project: "Default project" (id 512758) on US cloud.
NEXT_PUBLIC_POSTHOG_KEY=phc_m4jLiV27PjqhvhHisQgidwCLNSUyQ9rj3uRhro8WEbW5
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Local development config — read by `npm run dev`.
#
# Next.js reads .env.development (and .env.local) in dev, but NOT
# .env.production — so without this file, `npm run dev` on a fresh clone has
# no PostHog key and the SDK never initializes (nothing shows up in PostHog).
# The phc_ key is a public, client-side project token (safe to commit — it's
# already in .env.production and .env.example); it is NOT a secret.
NEXT_PUBLIC_POSTHOG_KEY=phc_m4jLiV27PjqhvhHisQgidwCLNSUyQ9rj3uRhro8WEbW5
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
